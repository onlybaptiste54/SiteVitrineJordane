        "messages": {
          "values": [
            {
              "role": "system",
              "content": "Tu es un expert en estimation immobilière sur le Grand Nancy (Meurthe-et-Moselle, France). Tu connais les prix du marché local 2024-2025. Réponds UNIQUEMENT avec un JSON valide sur une seule ligne, sans markdown, sans explication : {\"prixBas\": number, \"prixHaut\": number, \"commentaire\": string}. Le commentaire : une phrase courte (max 20 mots) pertinente sur le bien ou le marché."
            },
            {
              "role": "user",
              "content": "={{ 'Bien à estimer : Type=' + $('Webhook MERINO').first().json.body.type + ', Surface=' + $('Webhook MERINO').first().json.body.surface + 'm², Adresse=' + $('Webhook MERINO').first().json.body.adresse + ', Chambres=' + ($('Webhook MERINO').first().json.body.chambres ?? 'non renseigné') + ', État intérieur=' + $('Webhook MERINO').first().json.body.etatInterieur + '/5, État parties communes=' + ($('Webhook MERINO').first().json.body.etatCommuns ?? 'N/A') + '/5, Année construction=' + ($('Webhook MERINO').first().json.body.anneeConstruction ?? 'non renseignée') + ', Balcon=' + ($('Webhook MERINO').first().json.body.surfaceBalcon ?? 0) + 'm², Terrasse=' + ($('Webhook MERINO').first().json.body.surfaceTerrasse ?? 0) + 'm², Jardin=' + ($('Webhook MERINO').first().json.body.surfaceJardin ?? 0) + 'm², Parking intérieur=' + ($('Webhook MERINO').first().json.body.statInterieur ?? 0) + ', Parking extérieur=' + ($('Webhook MERINO').first().json.body.statExterieur ?? 0) + '.' }}"
            }
          ]
        },
        "options": {
          "maxTokens": 400
        }
      },
      "id": "aa000001-0004-0004-0004-000000000004",
      "name": "Claude Haiku - Estimation",
      "type": "@n8n/n8n-nodes-langchain.anthropic",
      "typeVersion": 1,
      "position": [80, 300],
      "credentials": {
        "anthropicApi": {
          "id": "SvRUQt6O0bdDgD2d",
          "name": "Anthropic account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parser la réponse de Claude + récupérer les données du lead\nconst claudeRaw = $input.first().json.text;\nconst lead = $('Webhook MERINO').first().json.body;\n\nlet estimation;\ntry {\n  const clean = claudeRaw.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  estimation = JSON.parse(clean);\n} catch (e) {\n  estimation = { prixBas: 0, prixHaut: 0, commentaire: 'Estimation à affiner avec nos experts.' };\n}\n\nconst formatPrice = (p) => new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(p);\n\nreturn [{\n  json: {\n    // Estimation Claude\n    prixBas: estimation.prixBas,\n    prixHaut: estimation.prixHaut,\n    prixBasFmt: formatPrice(estimation.prixBas),\n    prixHautFmt: formatPrice(estimation.prixHaut),\n    commentaire: estimation.commentaire,\n    // Lead\n    prenom: lead.prenom,\n    nom: lead.nom,\n    email: lead.email,\n    telephone: lead.telephone,\n    type: lead.type,\n    adresse: lead.adresse,\n    surface: lead.surface,\n    chambres: lead.chambres,\n    anneeConstruction: lead.anneeConstruction,\n    etatInterieur: lead.etatInterieur,\n    etatCommuns: lead.etatCommuns,\n    surfaceBalcon: lead.surfaceBalcon ?? 0,\n    surfaceTerrasse: lead.surfaceTerrasse ?? 0,\n    surfaceJardin: lead.surfaceJardin ?? 0,\n    statInterieur: lead.statInterieur ?? 0,\n    statExterieur: lead.statExterieur ?? 0,\n    agent: lead.agent ?? 'jordane',\n    agentNom: (lead.agent === 'louis') ? 'Louis PETITCOLIN' : 'Jordane MOREL',\n    agentEmail: (lead.agent === 'louis') ? 'louis@agencemerino.com' : 'jordane@agencemerino.com',\n    agentTel: (lead.agent === 'louis') ? '+33 7 59 59 92 97' : '+33 6 95 06 73 20',\n    soumisLe: new Date().toLocaleString('fr-FR', { timeZone: 'Europe/Paris' })\n  }\n}];"
      },
      "id": "aa000001-0005-0005-0005-000000000005",
      "name": "Parser Réponse Claude",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [340, 300]
    },
