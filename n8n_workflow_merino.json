    {
      "parameters": {
        "jsCode": "// Génère le contenu HTML des deux emails (agent + client)\nconst d = $input.first().json;\n\n// ── EMAIL AGENT (notification interne) ──────────────────────────────\nconst subjectAgent = `🏠 Nouveau lead – ${d.prenom} ${d.nom} – ${d.type} ${d.surface}m²`;\nconst htmlAgent = `\n<!DOCTYPE html><html><body style=\"margin:0;font-family:Arial,sans-serif;background:#f3f4f6\">\n<div style=\"max-width:600px;margin:0 auto;background:white;border-radius:12px;overflow:hidden;\">\n  <div style=\"background:#1a3a5c;padding:24px\">\n    <h1 style=\"color:white;margin:0;font-size:20px\">🏠 Nouveau lead MERINO</h1>\n    <p style=\"color:rgba(255,255,255,.7);margin:6px 0 0;font-size:13px\">${d.soumisLe}</p>\n  </div>\n  <div style=\"padding:24px\">\n    <h2 style=\"color:#1a3a5c;font-size:15px;border-bottom:2px solid #f97316;padding-bottom:6px\">Contact</h2>\n    <p style=\"margin:6px 0\"><strong>Nom :</strong> ${d.prenom} ${d.nom}</p>\n    <p style=\"margin:6px 0\"><strong>Email :</strong> <a href=\"mailto:${d.email}\">${d.email}</a></p>\n    <p style=\"margin:6px 0\"><strong>Tél :</strong> <a href=\"tel:${d.telephone}\">${d.telephone}</a></p>\n    <h2 style=\"color:#1a3a5c;font-size:15px;border-bottom:2px solid #f97316;padding-bottom:6px;margin-top:20px\">Bien</h2>\n    <p style=\"margin:6px 0\"><strong>Type :</strong> ${d.type}</p>\n    <p style=\"margin:6px 0\"><strong>Adresse :</strong> ${d.adresse}</p>\n    <p style=\"margin:6px 0\"><strong>Surface :</strong> ${d.surface}m²</p>\n    <p style=\"margin:6px 0\"><strong>Chambres :</strong> ${d.chambres ?? 'NR'}</p>\n    <p style=\"margin:6px 0\"><strong>Année :</strong> ${d.anneeConstruction ?? 'NR'}</p>\n    <p style=\"margin:6px 0\"><strong>État int. :</strong> ${d.etatInterieur}/5 · Communs : ${d.etatCommuns ?? 'N/A'}/5</p>\n    <p style=\"margin:6px 0\"><strong>Extérieurs :</strong> Balcon ${d.surfaceBalcon}m² · Terrasse ${d.surfaceTerrasse}m² · Jardin ${d.surfaceJardin}m²</p>\n    <p style=\"margin:6px 0\"><strong>Parking :</strong> ${d.statInterieur} int. / ${d.statExterieur} ext.</p>\n    <h2 style=\"color:#1a3a5c;font-size:15px;border-bottom:2px solid #f97316;padding-bottom:6px;margin-top:20px\">Estimation IA (Claude Haiku)</h2>\n    <div style=\"background:#f0f9ff;padding:16px;border-radius:8px;border-left:4px solid #f97316\">\n      <p style=\"font-size:22px;font-weight:bold;color:#1a3a5c;margin:0\">${d.prixBasFmt} — ${d.prixHautFmt}</p>\n      <p style=\"color:#6b7280;margin:6px 0 0;font-style:italic;font-size:13px\">${d.commentaire}</p>\n    </div>\n  </div>\n</div></body></html>`;\n\n// ── EMAIL CLIENT ─────────────────────────────────────────────────────\nconst subjectClient = `Votre estimation MERINO – ${d.type} à ${d.adresse.split(',')[0]}`;\nconst htmlClient = `\n<!DOCTYPE html><html><body style=\"margin:0;font-family:Arial,sans-serif;background:#f3f4f6\">\n<div style=\"max-width:600px;margin:0 auto;background:white;border-radius:12px;overflow:hidden;\">\n  <div style=\"background:#1a3a5c;padding:32px 24px;text-align:center\">\n    <h1 style=\"color:white;margin:0;font-size:26px\">Votre estimation est prête</h1>\n    <p style=\"color:rgba(255,255,255,.7);margin:8px 0 0\">MERINO Immobilier · Grand Nancy</p>\n  </div>\n  <div style=\"padding:32px 24px\">\n    <p style=\"font-size:16px;color:#374151\">Bonjour <strong>${d.prenom}</strong>,</p>\n    <p style=\"color:#6b7280\">Voici la fourchette de marché estimée pour votre <strong>${d.type}</strong> situé au <strong>${d.adresse}</strong> :</p>\n    <div style=\"background:linear-gradient(135deg,#f0f9ff,#e0f2fe);padding:28px;border-radius:12px;text-align:center;margin:24px 0;border:1px solid #bae6fd\">\n      <p style=\"color:#64748b;font-size:12px;text-transform:uppercase;letter-spacing:1px;margin:0 0 8px\">Fourchette estimée</p>\n      <p style=\"font-size:30px;font-weight:800;color:#1a3a5c;margin:0\">${d.prixBasFmt}</p>\n      <p style=\"font-size:14px;color:#94a3b8;margin:4px 0\">à</p>\n      <p style=\"font-size:30px;font-weight:800;color:#1a3a5c;margin:0\">${d.prixHautFmt}</p>\n      <p style=\"color:#f97316;font-style:italic;font-size:13px;margin:12px 0 0\">${d.commentaire}</p>\n    </div>\n    <p style=\"color:#6b7280;font-size:14px\">Cette estimation est indicative. Je vous rappelle sous 24h pour organiser une visite et vous proposer une évaluation complète.</p>\n  </div>\n</body></html>`;\n\nreturn [{\n  json: {\n    // Agent\n    subjectAgent,\n    htmlAgent,\n    emailAgent: d.agentEmail,\n    // Client\n    subjectClient,\n    htmlClient,\n    emailClient: d.email,\n    // Forward les données pour les noeuds suivants\n    ...d\n  }\n}];"
      },
