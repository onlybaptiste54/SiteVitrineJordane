    {
      "parameters": {
        "jsCode": "// Adapté de ton SetFooter existant — supporte jordane et louis\nconst emailData = $('Générer Contenu Emails').first().json;\nconst fileId = $input.item.json.id ||\n  (emailData.agent === 'louis' ? 'REMPLACER_PHOTO_FILE_ID_LOUIS' : '1O-nR69A2Yni4mawAPGK2MOBZpULvp_Bc');\n\nconst isLouis = emailData.agent === 'louis';\nconst agentInfo = isLouis\n  ? { name: 'Louis PETITCOLIN', phone: '+33 7 59 59 92 97', email: 'louis@agencemerino.com' }\n  : { name: 'Jordane MOREL',    phone: '+33 6 95 06 73 20', email: 'jordane@agencemerino.com' };\n\nconst firstName = agentInfo.name.split(' ')[0];\nconst lastName  = agentInfo.name.split(' ').slice(1).join(' ');\nconst photoUrl  = `https://drive.google.com/uc?id=${fileId}&export=view`;\n\nconst footerHtml = `\n  <hr style=\"margin-top:32px;border:none;border-top:1px solid #ddd\">\n  <table role=\"presentation\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\"\n         style=\"width:100%;max-width:600px;font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#333;line-height:1.4\">\n    <tr>\n      <td style=\"width:90px;vertical-align:top;padding-right:10px\">\n        <img src=\"${photoUrl}\" alt=\"${agentInfo.name}\" width=\"80\" height=\"80\"\n             style=\"display:block;border-radius:50%;border:3px solid #57728c;max-width:80px\">\n      </td>\n      <td style=\"width:220px;vertical-align:top;padding-right:15px\">\n        <p style=\"margin:0 0 4px;font-size:15px;line-height:1.3\">\n          <span style=\"font-weight:normal\">${firstName}</span>\n          <strong style=\"color:#44556e;font-weight:bold\">${lastName}</strong>\n        </p>\n        <p style=\"margin:0 0 2px;font-size:13px;color:#666\">Agent immobilier</p>\n        <p style=\"margin:0;font-size:13px;color:#666\">Co-fondateur | Merino</p>\n      </td>\n      <td style=\"vertical-align:top;padding-left:15px;border-left:2px solid #ddd\">\n        <p style=\"margin:0 0 6px;font-size:13px\">\n          <a href=\"tel:${agentInfo.phone.replace(/\\s/g,'')}\" style=\"color:#333;text-decoration:none\">${agentInfo.phone}</a>\n        </p>\n        <p style=\"margin:0 0 6px;font-size:13px\">\n          <a href=\"mailto:${agentInfo.email}\" style=\"color:#57728c;text-decoration:none\">${agentInfo.email}</a>\n        </p>\n        <p style=\"margin:0 0 6px;font-size:13px\">\n          <a href=\"https://www.agencemerino.com\" style=\"color:#57728c;text-decoration:none\">www.agencemerino.com</a>\n        </p>\n        <p style=\"margin:0;font-size:13px;color:#666\">171 Rue de Newcastle, 54000 Nancy</p>\n      </td>\n    </tr>\n  </table>\n`;\n\nreturn [{ json: { footerHtml } }];"
      },
